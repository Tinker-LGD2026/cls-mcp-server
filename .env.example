# 腾讯云 CLS MCP Server 配置
# ==============================

# ======================== 认证配置 ========================

# [必填] 腾讯云 API 密钥
CLS_SECRET_ID=your-secret-id-here
CLS_SECRET_KEY=your-secret-key-here

# ======================== 地域配置 ========================

# [可选] 默认地域（工具调用时可通过 region 参数动态覆盖），默认 ap-guangzhou
CLS_REGION=ap-guangzhou

# ======================== 传输与网络 ========================

# [可选] 传输方式: stdio | sse | streamable-http，默认 stdio
CLS_TRANSPORT=stdio

# [可选] HTTP 监听地址（SSE/Streamable HTTP 模式），默认 0.0.0.0
# 向后兼容 CLS_SSE_HOST
CLS_HOST=0.0.0.0

# [可选] HTTP 监听端口（SSE/Streamable HTTP 模式），默认 8000
# 向后兼容 CLS_SSE_PORT
CLS_PORT=8000

# [可选] Streamable HTTP 无状态模式，推荐 K8s 部署时开启，默认 true
CLS_STATELESS_HTTP=true

# ======================== 权限控制 ========================

# [可选] 设置为 true 开启写操作工具（创建、修改），默认 false
CLS_ENABLE_WRITE=false

# [可选] 设置为 true 开启高危操作工具（删除），需同时开启 CLS_ENABLE_WRITE，默认 false
CLS_ENABLE_DANGEROUS=false

# ======================== 认证安全 ========================

# [可选] HTTP Bearer Token 认证（SSE/Streamable HTTP 模式）
# 设置后，客户端请求需带 Authorization: Bearer <token> 头
# MCP_AUTH_TOKEN=your-secret-token-here

# ======================== 请求超时 ========================

# [可选] SDK 请求超时（秒），部分接口较慢可适当调大，默认 60
CLS_REQUEST_TIMEOUT=60

# ======================== 重试策略 ========================

# [可选] 最大重试次数（含首次调用），默认 3
CLS_RETRY_MAX_ATTEMPTS=3

# [可选] 重试基础退避延迟（秒），默认 1.0
CLS_RETRY_BASE_DELAY=1.0

# ======================== 熔断器配置 ========================

# [可选] 连续失败多少次后触发熔断，默认 5
CLS_CB_FAILURE_THRESHOLD=5

# [可选] 熔断后多少秒进入半开状态尝试恢复，默认 30
CLS_CB_RECOVERY_TIMEOUT=30

# ======================== 工具白名单 ========================

# [可选] 只注册指定的工具（逗号分隔），为空则注册全部工具
# 示例: CLS_ENABLED_TOOLS=cls_search_log,cls_get_log_histogram,cls_describe_topics
# CLS_ENABLED_TOOLS=

# ======================== 日志 ========================

# [可选] 日志级别: DEBUG | INFO | WARNING | ERROR，默认 INFO
CLS_LOG_LEVEL=INFO
